# With a key present, stage 1 uses OpenAI by default. Without one it uses the
# deterministic fixture provider. Set the provider explicitly to override.
OPENAI_API_KEY=

# Keep model selection configurable and evaluate changes before promotion.
OPENAI_MODEL=gpt-5.6
# Optional: openai, mock, or auto. Blank selects OpenAI when a key exists.
QUESTION_PLAN_PROVIDER=
QUESTION_PLAN_TIMEOUT_MS=180000

# Server-to-server connection from the Next.js BFF to FastAPI.
PURCHASE_ORCHESTRATOR_URL=http://127.0.0.1:8000

# Demo identity/address used until an authenticated user profile is connected.
PURCHASE_DEMO_USER_ID=10000000-0000-4000-8000-000000000002
PURCHASE_DEMO_ADDRESS_ID=10000000-0000-4000-8000-000000000004
PURCHASE_DEMO_RECIPIENT_NAME=Jan Testowy
PURCHASE_DEMO_EMAIL=jan.testowy@example.com
PURCHASE_DEMO_PHONE=+48111222333
PURCHASE_DEMO_ADDRESS_LINE1=Testowa 1
PURCHASE_DEMO_POSTAL_CODE=00-001
PURCHASE_DEMO_CITY=Warszawa
PURCHASE_DEMO_COUNTRY_CODE=PL

# Optional: powers realtime synchronization on the isolated /whatsapp UI.
# These are Firebase web-app identifiers (not Admin SDK secrets). Enable
# Anonymous Authentication and deploy firestore.rules before using it.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
